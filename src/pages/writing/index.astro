---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const posts = (await getCollection("writing")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const featured = posts.filter((post) => post.data.featured);
---

<BaseLayout title="文章 - dd-y / 余非凡" description="关于 RAG、Agent、评测与 AI 工程系统的长文章。">
  <section class="writing-page page-shell">
    <header>
      <p data-i18n-zh="文章" data-i18n-en="Writing">文章</p>
      <h1 data-i18n-zh="文章" data-i18n-en="WRITING">文章</h1>
      <span
        data-i18n-zh="技术文章、系统设计笔记，以及从模型能力走向系统能力的思考。"
        data-i18n-en="Technical essays, system design notes, and thinking from model capability to system capability."
      >
        技术文章、系统设计笔记，以及从模型能力走向系统能力的思考。
      </span>
    </header>

    <div class="writing-page__featured">
      {featured.map((post) => (
        <a href={`/writing/${post.id}`}>
          <small
            data-i18n-zh={`${post.data.tags.join(" · ")} · ${post.data.minutes} 分钟阅读`}
            data-i18n-en={`${post.data.tags.join(" · ")} · ${post.data.minutes} min read`}
          >
            {post.data.tags.join(" · ")} · {post.data.minutes} 分钟阅读
          </small>
          <strong data-i18n-zh={post.data.title} data-i18n-en={post.data.titleEn}>{post.data.title}</strong>
          <p data-i18n-zh={post.data.description} data-i18n-en={post.data.descriptionEn}>{post.data.description}</p>
        </a>
      ))}
    </div>

    <div class="writing-page__list">
      {posts.map((post) => (
        <a href={`/writing/${post.id}`}>
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toISOString().slice(0, 10)}
          </time>
          <strong data-i18n-zh={post.data.title} data-i18n-en={post.data.titleEn}>{post.data.title}</strong>
          <span data-i18n-zh={`${post.data.minutes} 分钟`} data-i18n-en={`${post.data.minutes} min`}>
            {post.data.minutes} 分钟
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .writing-page {
    padding-top: clamp(3rem, 7vw, 6rem);
  }

  header {
    display: grid;
    grid-template-columns: minmax(0, 0.55fr) minmax(0, 0.45fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: end;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  header p {
    grid-column: 1 / -1;
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 12vw, 11rem);
    font-weight: 850;
    line-height: 0.82;
  }

  header span {
    max-width: 25rem;
    font-size: clamp(1.1rem, 1.8vw, 1.45rem);
    line-height: 1.65;
  }

  .writing-page__featured {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
    margin-bottom: 3rem;
  }

  .writing-page__featured a {
    min-height: 18rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: clamp(1.2rem, 3vw, 2rem);
  }

  .writing-page__featured small,
  .writing-page__list time,
  .writing-page__list span {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .writing-page__featured strong {
    display: block;
    margin-top: 2rem;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.6rem);
    line-height: 1.1;
  }

  .writing-page__featured p {
    max-width: 34rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .writing-page__list {
    border-top: 1px solid var(--color-line);
  }

  .writing-page__list a {
    display: grid;
    grid-template-columns: 8rem minmax(0, 1fr) 4rem;
    gap: 1rem;
    align-items: center;
    border-bottom: 1px solid var(--color-line);
    padding-block: 1.1rem;
  }

  .writing-page__list strong {
    font-size: 1.05rem;
  }

  @media (max-width: 760px) {
    header,
    .writing-page__featured {
      grid-template-columns: 1fr;
    }

    .writing-page__list a {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
