---
import { getCollection } from "astro:content";
import { ProjectPreview } from "@/components/islands/ProjectPreview";
import SectionLabel from "@/components/SectionLabel.astro";

const works = (await getCollection("work")).sort((a, b) => a.data.order - b.data.order);
const projects = works.map((work) => ({
  title: work.data.title,
  role: work.data.role,
  year: work.data.year,
  href: `/work/${work.id}`
}));
---

<section class="selected-work page-shell" id="work" data-section-marker="Selected Systems" data-section-tone="focus">
  <SectionLabel label="Selected Systems" labelEn="Selected Systems" kicker="Proof of work" kickerEn="Proof of work" />
  <ProjectPreview projects={projects} client:visible />
</section>

<style>
  .selected-work {
    border-top: 1px solid var(--color-line);
    padding-block: clamp(3rem, 7vw, 6rem);
  }

  :global(.project-preview) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.76fr);
    gap: clamp(2rem, 5vw, 4rem);
    margin-top: 1.8rem;
  }

  :global(.project-preview__list) {
    border-top: 1px solid var(--color-line);
  }

  :global(.work-row) {
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr) 4rem;
    gap: 1rem;
    align-items: center;
    border-bottom: 1px solid var(--color-line);
    padding-block: 1.25rem;
    transition:
      padding 180ms ease,
      background 180ms ease;
  }

  :global(.work-row:hover),
  :global(.work-row[data-active="true"]) {
    padding-left: 0.8rem;
    background: rgba(199, 244, 50, 0.08);
  }

  :global(.work-row__index),
  :global(.work-row__year) {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  :global(.work-row strong) {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.5vw, 1.35rem);
  }

  :global(.work-row small) {
    display: block;
    margin-top: 0.35rem;
    color: var(--color-muted);
  }

  :global(.selected-work__preview) {
    min-height: 20rem;
    border: 1px solid var(--color-line);
    padding: clamp(1rem, 3vw, 2rem);
    background: rgba(255, 255, 255, 0.16);
  }

  :global(.selected-work__preview-title) {
    display: grid;
    gap: 0.35rem;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  :global(.selected-work__preview-title small) {
    color: var(--color-muted);
    font-size: 0.68rem;
  }

  :global(.preview-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    height: 100%;
    align-content: center;
    margin-top: 1.5rem;
  }

  :global(.preview-grid span) {
    border: 1px solid var(--color-line);
    padding: 0.8rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-align: center;
  }

  :global(.preview-grid .active) {
    grid-column: 1 / -1;
    border-color: var(--color-lime);
    color: var(--color-ink);
  }

  @media (max-width: 820px) {
    :global(.project-preview) {
      grid-template-columns: 1fr;
    }
  }
</style>
