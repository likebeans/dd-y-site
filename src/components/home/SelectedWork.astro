---
import { getCollection } from "astro:content";
import SectionLabel from "@/components/SectionLabel.astro";

const works = (await getCollection("work")).sort((a, b) => a.data.order - b.data.order);
---

<section class="selected-work page-shell" id="work">
  <SectionLabel label="Selected Work" kicker="Case studies" />
  <div class="selected-work__layout">
    <div class="selected-work__list">
      {
        works.map((work) => (
          <a class="work-row" href={`/work/${work.id}`}>
            <span class="work-row__index">{String(work.data.order).padStart(2, "0")}</span>
            <span>
              <strong>{work.data.title}</strong>
              <small>{work.data.role}</small>
            </span>
            <span class="work-row__year">{work.data.year}</span>
          </a>
        ))
      }
    </div>
    <aside class="selected-work__preview" aria-label="Architecture preview">
      <div class="preview-grid">
        <span>User</span>
        <span class="active">Agent Runtime</span>
        <span>Retrieval</span>
        <span>Tools</span>
        <span>Business System</span>
      </div>
    </aside>
  </div>
</section>

<style>
  .selected-work {
    border-top: 1px solid var(--color-line);
    padding-block: clamp(3rem, 7vw, 6rem);
  }

  .selected-work__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.76fr);
    gap: clamp(2rem, 5vw, 4rem);
    margin-top: 1.8rem;
  }

  .selected-work__list {
    border-top: 1px solid var(--color-line);
  }

  .work-row {
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr) 4rem;
    gap: 1rem;
    align-items: center;
    border-bottom: 1px solid var(--color-line);
    padding-block: 1.25rem;
    transition:
      padding 180ms ease,
      background 180ms ease;
  }

  .work-row:hover {
    padding-left: 0.8rem;
    background: rgba(199, 244, 50, 0.08);
  }

  .work-row__index,
  .work-row__year {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .work-row strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.5vw, 1.35rem);
  }

  .work-row small {
    display: block;
    margin-top: 0.35rem;
    color: var(--color-muted);
  }

  .selected-work__preview {
    min-height: 20rem;
    border: 1px solid var(--color-line);
    padding: clamp(1rem, 3vw, 2rem);
    background: rgba(255, 255, 255, 0.16);
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    height: 100%;
    align-content: center;
  }

  .preview-grid span {
    border: 1px solid var(--color-line);
    padding: 0.8rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-align: center;
  }

  .preview-grid .active {
    grid-column: 1 / -1;
    border-color: var(--color-lime);
    color: var(--color-ink);
  }

  @media (max-width: 820px) {
    .selected-work__layout {
      grid-template-columns: 1fr;
    }
  }
</style>
