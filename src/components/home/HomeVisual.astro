---
import SectionLabel from "@/components/SectionLabel.astro";
---

<section class="home-visual page-shell" data-section-marker="Visual Field" data-section-tone="focus" data-home-visual>
  <SectionLabel label="图像区域" labelEn="Visual Field" kicker="图片归档" kickerEn="Image archive" />
  <div class="home-visual__grid">
    <div class="home-visual__copy">
      <p
        data-i18n-zh="这里预留一个视觉展示区，用来承载项目截图、架构图、工作现场照片或你想长期展示的代表性图片。"
        data-i18n-en="This visual field is reserved for project screenshots, architecture diagrams, field photos, or one defining image you want the homepage to carry."
      >
        这里预留一个视觉展示区，用来承载项目截图、架构图、工作现场照片或你想长期展示的代表性图片。
      </p>
      <dl>
        <div>
          <dt data-i18n-zh="格式" data-i18n-en="FORMAT">格式</dt>
          <dd data-i18n-zh="宽幅图片 / 系统图 / 产品截图" data-i18n-en="Wide image / system diagram / product screenshot">
            宽幅图片 / 系统图 / 产品截图
          </dd>
        </div>
        <div>
          <dt data-i18n-zh="作用" data-i18n-en="ROLE">作用</dt>
          <dd data-i18n-zh="让页面在纯文本之外有一个记忆点" data-i18n-en="Give the page one visual memory beyond text">
            让页面在纯文本之外有一个记忆点
          </dd>
        </div>
      </dl>
    </div>
    <figure class="home-visual__media">
      <img src="/home-visual.svg" alt="首页图片槽位：视觉归档占位" loading="lazy" />
      <figcaption>
        <strong data-i18n-zh="系统图占位" data-i18n-en="System visual placeholder">
          系统图占位
        </strong>
        <span data-i18n-zh="图片位置" data-i18n-en="Image slot">图片位置</span>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .home-visual {
    padding-block: clamp(3.5rem, 7vw, 7rem);
  }

  .home-visual__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.62fr) minmax(0, 1.38fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: stretch;
    margin-top: 1.8rem;
  }

  .home-visual__copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
  }

  .home-visual__copy p {
    max-width: 30rem;
    margin: 0;
    font-size: clamp(1.12rem, 1.7vw, 1.55rem);
    line-height: 1.65;
  }

  dl {
    display: grid;
    gap: 1rem;
    margin: 0;
    border-top: 1px solid var(--color-line);
  }

  dl div {
    border-bottom: 1px solid var(--color-line);
    padding-block: 1rem;
  }

  dt {
    margin-bottom: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .home-visual__media {
    position: relative;
    margin: 0;
    border: 1px solid var(--color-line-strong);
    background: rgba(255, 255, 255, 0.18);
    overflow: hidden;
  }

  .home-visual__media img {
    width: 100%;
    height: 100%;
    min-height: clamp(20rem, 38vw, 36rem);
    object-fit: cover;
    filter: saturate(0.94) contrast(1.02);
  }

  figcaption {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid rgba(17, 17, 17, 0.18);
    padding-top: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  figcaption span {
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .home-visual__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .home-visual__media img {
      min-height: 18rem;
    }

    figcaption {
      position: static;
      border-top: 1px solid var(--color-line);
      padding: 0.8rem 1rem;
    }
  }
</style>
