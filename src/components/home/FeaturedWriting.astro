---
import { getCollection } from "astro:content";
import ArrowLink from "@/components/ArrowLink.astro";
import SectionLabel from "@/components/SectionLabel.astro";

const posts = (await getCollection("writing"))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 2);
---

<section class="featured-writing page-shell" data-section-marker="Current Thinking" data-section-tone="quiet">
  <SectionLabel label="当前思考" labelEn="Current Thinking" kicker="最新文章" kickerEn="Latest writing" />
  <div class="featured-writing__grid">
    {
      posts.map((post, index) => (
        <a class:list={["writing-row", index === 0 && "writing-row--lead"]} href={`/writing/${post.id}`}>
          <span class="writing-row__meta">
            <span
              data-i18n-zh={`${post.data.tags.join(" · ")} · ${post.data.minutes} 分钟阅读`}
              data-i18n-en={`${post.data.tags.join(" · ")} · ${post.data.minutes} min read`}
            >
              {post.data.tags.join(" · ")} · {post.data.minutes} 分钟阅读
            </span>
          </span>
          <strong data-i18n-zh={post.data.title} data-i18n-en={post.data.titleEn}>
            {post.data.title}
          </strong>
          <p
            data-i18n-zh={post.data.description}
            data-i18n-en={post.data.descriptionEn}
          >
            {post.data.description}
          </p>
        </a>
      ))
    }
  </div>
  <ArrowLink href="/writing" label="查看全部文章" labelEn="VIEW ALL WRITING" />
</section>

<style>
  .featured-writing {
    padding-block: clamp(3rem, 7vw, 6rem);
  }

  .featured-writing__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 0;
    margin: 1.8rem 0 1.5rem;
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  .writing-row {
    min-height: 17rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: clamp(1.2rem, 3vw, 2rem);
    transition: background 180ms ease;
  }

  .writing-row:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  .writing-row--lead {
    min-height: 24rem;
  }

  .writing-row__meta {
    display: block;
    margin-bottom: 2.4rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .writing-row strong {
    display: block;
    max-width: 16em;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.4vw, 2.15rem);
    line-height: 1.18;
  }

  .writing-row p {
    max-width: 32rem;
    margin: 1rem 0 0;
    color: var(--color-muted);
    line-height: 1.7;
  }

  @media (max-width: 820px) {
    .featured-writing__grid {
      grid-template-columns: 1fr;
    }

    .writing-row,
    .writing-row--lead {
      min-height: auto;
    }
  }
</style>
