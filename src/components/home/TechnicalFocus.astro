---
import SectionLabel from "@/components/SectionLabel.astro";

const focus = [
  ["RAG", "RAG", "复杂文档解析、切分、检索、重排与评测。", "Document parsing, chunking, retrieval, reranking, and evaluation."],
  ["Agent", "Agent", "状态管理、工具调用、人工审批、日志与可观测性。", "State, tool calling, human approval, logging, and observability."],
  ["Evaluation", "Evaluation", "任务数据集、trace 分析、答案质量和可靠性验证。", "Task datasets, trace analysis, answer quality, and reliability checks."],
  ["Engineering", "Engineering", "权限、延迟、失败归因、成本与可维护边界。", "Permissions, latency, failure attribution, cost, and maintainable boundaries."]
];
---

<section class="technical-focus page-shell" data-home-section="07" data-section-tone="surface">
  <SectionLabel label="Technical Focus" labelEn="Technical Focus" kicker="Models to systems" kickerEn="Models to systems" />
  <div class="technical-focus__grid">
    {
      focus.map(([title, titleEn, text, textEn]) => (
        <article>
          <h3 data-i18n-zh={title} data-i18n-en={titleEn}>{title}</h3>
          <p data-i18n-zh={text} data-i18n-en={textEn}>{text}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .technical-focus {
    padding-block: clamp(3rem, 7vw, 6rem);
  }

  .technical-focus__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 1.8rem;
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  article {
    min-height: 12rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: 1.4rem;
  }

  h3 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  p {
    margin: 2.25rem 0 0;
    color: var(--color-muted);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .technical-focus__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .technical-focus__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
