---
import SectionLabel from "@/components/SectionLabel.astro";

const focus = [
  ["RAG", "Document parsing, chunking, hybrid retrieval and reranking."],
  ["Agent", "Runtime, state, approval, tool calling and observability."],
  ["Evaluation", "Task datasets, trace analysis, answer quality and reliability."],
  ["Engineering", "Production boundaries, latency, permissions and maintainability."]
];
---

<section class="technical-focus page-shell">
  <SectionLabel label="Technical Focus" kicker="Models to systems" />
  <div class="technical-focus__grid">
    {
      focus.map(([title, text]) => (
        <article>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .technical-focus {
    padding-block: clamp(3rem, 7vw, 6rem);
  }

  .technical-focus__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 1.8rem;
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  article {
    min-height: 12rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: 1.4rem;
  }

  h3 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  p {
    margin: 2.25rem 0 0;
    color: var(--color-muted);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .technical-focus__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .technical-focus__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
