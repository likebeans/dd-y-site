---
import ArrowLink from "@/components/ArrowLink.astro";
import { SystemTrace } from "@/components/islands/SystemTrace";
import { profile } from "@/data/profile";
---

<section class="hero page-shell" data-section-marker="Home" data-section-tone="quiet">
  <div class="hero__grid">
    <div class="hero__copy">
      <p
        class="hero__role"
        data-i18n-zh={profile.role}
        data-i18n-en="AI Systems Engineer / Large Language Models"
      >
        {profile.role}
      </p>
      <h1 class="hero__headline">
        <span class="hero__headline-line" data-i18n-zh="从模型能力" data-i18n-en="FROM MODELS">从模型能力</span>
        <span class="hero__headline-line" data-i18n-zh="到系统能力" data-i18n-en="TO SYSTEMS">到系统能力</span>
      </h1>
      <p
        class="hero__thesis"
        data-i18n-zh={profile.thesis}
        data-i18n-en="Turning model capability into systems that ship, measure, and endure."
      >
        {profile.thesis}
      </p>
      <p
        class="hero__intro"
        data-i18n-zh={profile.intro}
        data-i18n-en="I care about one thing: turning model capability into reliable systems."
      >
        {profile.intro}
      </p>
      <div class="hero__actions">
        <ArrowLink href="/writing" label="阅读文章" labelEn="READ WRITING" variant="primary" />
        <ArrowLink href="/work" label="查看项目" labelEn="VIEW SYSTEMS" />
        <ArrowLink href="/resume" label="获取简历" labelEn="GET RESUME" />
      </div>
    </div>

    <aside class="hero__diagram" aria-label="Agent Runtime Harness" data-runtime-harness>
      <div class="hero__diagram-meta mono">
        <span>Agent Runtime Harness</span>
        <span>Loop ID 000512</span>
        <span>Trace 000128</span>
      </div>
      <div class="runtime-blueprint">
        <div class="runtime-blueprint__title mono">
          <span>Runtime Slice</span>
          <strong>Loop Engineering</strong>
        </div>
        <div class="runtime-boundary runtime-boundary--input">User Intent</div>
        <div class="runtime-boundary runtime-boundary--output">System Action</div>
        <div class="runtime-loop" aria-label="Plan Act Observe Evaluate">
          <span class="runtime-loop__path"></span>
          <span class="runtime-node runtime-node--plan">Plan</span>
          <span class="runtime-node runtime-node--act">Act</span>
          <span class="runtime-node runtime-node--observe">Observe</span>
          <span class="runtime-node runtime-node--evaluate">Evaluate</span>
          <div class="runtime-kernel" data-runtime-core>
            <span>Runtime Core</span>
            <strong>Agent Loop</strong>
            <small>stateful / tool-aware / auditable</small>
          </div>
        </div>
        <div class="runtime-core" aria-label="Runtime Harness controls">
          <span>State</span>
          <span>Tools</span>
          <span>Memory</span>
          <span>Policy</span>
        </div>
        <div class="runtime-guards" aria-label="Runtime guard rails">
          <span>Tool Boundary</span>
          <span>Human Gate</span>
          <span>Retry Path</span>
        </div>
        <dl class="runtime-signals">
          <div>
            <dt>Traceable</dt>
            <dd>event log</dd>
          </div>
          <div>
            <dt>Evaluable</dt>
            <dd>score gate</dd>
          </div>
          <div>
            <dt>Recoverable</dt>
            <dd>retry path</dd>
          </div>
        </dl>
      </div>
      <div class="diagram-cross diagram-cross--one"></div>
      <div class="diagram-cross diagram-cross--two"></div>
    </aside>
  </div>

  <SystemTrace client:visible />
</section>

<style>
  .hero {
    min-height: min(54rem, calc(92vh - 4.5rem));
    padding-top: clamp(1.5rem, 3.25vw, 3.25rem);
    padding-bottom: clamp(1.75rem, 4vw, 3rem);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(30rem, 1fr);
    gap: clamp(1.5rem, 3.2vw, 3.5rem);
    align-items: center;
  }

  .hero__copy {
    display: flex;
    min-width: 0;
    min-height: 34rem;
    flex-direction: column;
    justify-content: center;
  }

  .hero__role {
    margin: 0 0 1.4rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .hero__headline {
    max-width: 13ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(4.2rem, 8vw, 9.25rem);
    font-weight: 860;
    letter-spacing: 0;
    line-height: 0.84;
  }

  .hero__headline-line {
    display: block;
  }

  :global(html[data-language="en"]) .hero__headline {
    max-width: 10.8ch;
    font-size: clamp(4rem, 5.7vw, 6.35rem);
    line-height: 0.9;
  }

  :global(html[data-language="zh"]) .hero__headline {
    max-width: 12ch;
    font-size: clamp(3.9rem, 6.35vw, 7rem);
    font-weight: 820;
    line-height: 0.98;
  }

  :global(html[data-language="zh"]) .hero__headline-line + .hero__headline-line {
    margin-top: 0.1em;
  }

  .hero__thesis {
    max-width: 44rem;
    margin: clamp(1.4rem, 3vw, 2.4rem) 0 0;
    font-size: clamp(1.25rem, 2vw, 2rem);
    line-height: 1.35;
  }

  .hero__intro {
    max-width: 38rem;
    margin: 1.25rem 0 0;
    color: #3c3a35;
    font-size: clamp(1rem, 1.35vw, 1.18rem);
    line-height: 1.9;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 2rem;
  }

  .hero__diagram {
    position: relative;
    min-height: 34rem;
    margin-left: clamp(-1.25rem, -1.2vw, -0.5rem);
    background:
      linear-gradient(to right, transparent 49.8%, rgba(17, 17, 17, 0.08) 50%, transparent 50.2%),
      linear-gradient(to bottom, transparent 49.8%, rgba(17, 17, 17, 0.08) 50%, transparent 50.2%);
  }

  .hero__diagram::before {
    position: absolute;
    inset: 8% 0 9% 4%;
    content: "";
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-right: 0;
    border-bottom: 0;
  }

  .hero__diagram-meta {
    position: absolute;
    top: 0;
    right: 0;
    display: grid;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.66rem;
    text-align: right;
  }

  .runtime-blueprint {
    position: absolute;
    inset: 7.5% 0 4% 0;
  }

  .runtime-blueprint::before {
    position: absolute;
    inset: 0 0 0.2rem;
    content: "";
    border-top: 1px solid rgba(17, 17, 17, 0.12);
    border-bottom: 1px solid rgba(17, 17, 17, 0.1);
    background:
      linear-gradient(to right, rgba(17, 17, 17, 0.035) 1px, transparent 1px) 0 0 / 25% 100%,
      linear-gradient(to bottom, rgba(17, 17, 17, 0.035) 1px, transparent 1px) 0 0 / 100% 25%,
      rgba(255, 255, 255, 0.11);
    box-shadow:
      inset 1px 0 0 rgba(17, 17, 17, 0.06),
      inset -1px 0 0 rgba(17, 17, 17, 0.04);
  }

  .runtime-blueprint__title {
    position: absolute;
    top: 1rem;
    left: 1.1rem;
    display: grid;
    gap: 0.28rem;
    color: var(--color-muted);
    font-size: 0.58rem;
  }

  .runtime-blueprint__title strong {
    color: var(--color-ink);
    font-size: 0.75rem;
    font-weight: 760;
  }

  .runtime-boundary {
    position: absolute;
    z-index: 1;
    border: 1px solid rgba(17, 17, 17, 0.16);
    background: rgba(255, 255, 255, 0.32);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.56rem;
    text-transform: uppercase;
  }

  .runtime-boundary--input {
    top: 8.1rem;
    left: 1rem;
    padding: 0.5rem 0.65rem;
    writing-mode: vertical-rl;
  }

  .runtime-boundary--output {
    right: 1.1rem;
    bottom: 10.4rem;
    padding: 0.5rem 0.7rem;
  }

  .runtime-loop {
    position: absolute;
    top: 5.2rem;
    right: 0.7rem;
    left: 4.6rem;
    height: 15.1rem;
  }

  .runtime-loop__path {
    position: absolute;
    inset: 0.95rem 1.35rem 1rem 1.35rem;
    border: 2px solid rgba(199, 244, 50, 0.86);
    border-left-color: rgba(17, 17, 17, 0.18);
    border-bottom-color: rgba(17, 17, 17, 0.13);
    box-shadow: 0 0 0 1px rgba(199, 244, 50, 0.08);
  }

  .runtime-loop__path::before,
  .runtime-loop__path::after {
    position: absolute;
    content: "";
    background: rgba(17, 17, 17, 0.12);
  }

  .runtime-loop__path::before {
    top: 50%;
    right: -9%;
    left: -9%;
    height: 1px;
  }

  .runtime-loop__path::after {
    top: -11%;
    bottom: -11%;
    left: 50%;
    width: 1px;
  }

  .runtime-node,
  .runtime-core span {
    position: absolute;
    border: 1px solid var(--color-line);
    padding: 0.55rem 0.75rem;
    background: color-mix(in srgb, var(--color-paper) 86%, white);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
  }

  .runtime-node--plan {
    top: 0.15rem;
    left: 0.95rem;
  }

  .runtime-node--act {
    top: 1.75rem;
    right: 0;
    border-color: var(--color-lime);
    box-shadow: 0 0 0 1px rgba(199, 244, 50, 0.22);
  }

  .runtime-node--observe {
    right: 3.95rem;
    bottom: 0;
  }

  .runtime-node--evaluate {
    bottom: 1.2rem;
    left: 1.95rem;
  }

  .runtime-kernel {
    position: absolute;
    top: 4.85rem;
    left: 50%;
    z-index: 2;
    display: grid;
    width: min(74%, 23rem);
    min-height: 7rem;
    border: 1px solid rgba(17, 17, 17, 0.9);
    padding: 1rem 1.2rem;
    background: rgba(17, 17, 17, 0.94);
    color: var(--color-paper);
    font-family: var(--font-mono);
    transform: translateX(-50%);
  }

  .runtime-kernel span {
    color: rgba(236, 230, 220, 0.62);
    font-size: 0.62rem;
    text-transform: uppercase;
  }

  .runtime-kernel strong {
    margin-top: 0.55rem;
    color: var(--color-paper);
    font-size: clamp(1.15rem, 1.7vw, 1.55rem);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .runtime-kernel small {
    margin-top: 0.75rem;
    color: rgba(199, 244, 50, 0.82);
    font-size: 0.62rem;
    text-transform: uppercase;
  }

  .runtime-core {
    position: absolute;
    right: 0;
    bottom: 6.9rem;
    left: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.38rem;
    align-items: flex-start;
    min-height: 3.5rem;
    border-top: 1px solid rgba(17, 17, 17, 0.1);
    padding-top: 0.8rem;
  }

  .runtime-core::before {
    position: absolute;
    top: 1.85rem;
    right: 0;
    left: 0;
    height: 1px;
    content: "";
    background: linear-gradient(90deg, rgba(199, 244, 50, 0.78), rgba(17, 17, 17, 0.08));
  }

  .runtime-core span {
    position: relative;
    display: inline-grid;
    place-items: center;
    min-width: 4.5rem;
    margin: 0;
    padding: 0.42rem 0.55rem;
    font-size: 0.56rem;
  }

  .runtime-guards {
    position: absolute;
    right: 1rem;
    bottom: 4.4rem;
    left: 1rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.42rem;
  }

  .runtime-guards span {
    border: 1px solid rgba(17, 17, 17, 0.13);
    padding: 0.42rem 0.55rem;
    background: rgba(255, 255, 255, 0.18);
    color: #35332f;
    font-family: var(--font-mono);
    font-size: 0.54rem;
    text-align: center;
    text-transform: uppercase;
  }

  .runtime-signals {
    position: absolute;
    right: 1rem;
    bottom: 0.15rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    width: calc(100% - 2rem);
    border-top: 1px solid var(--color-line);
    margin: 0;
  }

  .runtime-signals div {
    padding: 0.7rem 0.75rem 0;
  }

  .runtime-signals div + div {
    border-left: 1px solid var(--color-line);
  }

  .runtime-signals dt {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  .runtime-signals dd {
    margin: 0.35rem 0 0;
    color: var(--color-muted);
    font-size: 0.7rem;
  }

  .diagram-cross {
    position: absolute;
    width: 2rem;
    height: 2rem;
  }

  .diagram-cross::before,
  .diagram-cross::after {
    position: absolute;
    background: var(--color-line-strong);
    content: "";
  }

  .diagram-cross::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
  }

  .diagram-cross::after {
    top: 0;
    left: 50%;
    width: 1px;
    height: 100%;
  }

  .diagram-cross--one {
    top: 10%;
    right: 24%;
  }

  .diagram-cross--two {
    bottom: 7%;
    left: 18%;
  }

  :global(.system-trace) {
    position: relative;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1.4rem;
    margin-top: clamp(2rem, 4vw, 3.75rem);
    padding-top: 1.65rem;
  }

  :global(.system-trace__line) {
    position: absolute;
    top: 0.25rem;
    right: 0;
    left: 0;
    height: 1px;
    background: var(--color-line);
  }

  :global(.system-trace__line span) {
    display: block;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, var(--color-lime), var(--color-line));
    transform-origin: left;
  }

  :global(.system-trace__node) {
    position: relative;
    display: grid;
    gap: 0.55rem;
    min-height: 5rem;
  }

  :global(.system-trace__dot) {
    position: absolute;
    top: -1.75rem;
    left: 0;
    width: 0.58rem;
    height: 0.58rem;
    border: 1px solid var(--color-lime);
    background: var(--color-paper);
  }

  :global(.system-trace strong) {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
  }

  :global(.system-trace small) {
    max-width: 10rem;
    color: var(--color-muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  @media (max-width: 960px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }

    .hero__diagram {
      min-height: 18rem;
      border-top: 1px solid var(--color-line);
      border-left: 0;
    }

    :global(.system-trace) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      row-gap: 2rem;
    }
  }

  @media (min-width: 721px) {
    .hero__headline-line {
      white-space: nowrap;
    }
  }

  @media (max-width: 620px) {
    .hero {
      min-height: auto;
      padding-top: 1.8rem;
      padding-bottom: 1.4rem;
    }

    .hero__role {
      margin-bottom: 0.9rem;
      font-size: 0.68rem;
    }

    .hero__headline {
      font-size: clamp(3.55rem, 16vw, 4.2rem);
      line-height: 0.85;
    }

    :global(html[data-language="zh"]) .hero__headline {
      max-width: 8ch;
      font-size: clamp(3.15rem, 13vw, 4rem);
      line-height: 1;
    }

    .hero__thesis {
      margin-top: 1.1rem;
      font-size: 1.25rem;
    }

    .hero__intro {
      margin-top: 0.9rem;
      line-height: 1.75;
    }

    .hero__actions {
      margin-top: 1.45rem;
    }

    .hero__diagram {
      display: none;
    }

    :global(.system-trace) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem 1rem;
      margin-top: 1.55rem;
      padding-top: 0;
    }

    :global(.system-trace__line) {
      display: none;
    }

    :global(.system-trace__node) {
      gap: 0.4rem;
      min-height: 0;
      border-top: 1px solid var(--color-line);
      padding-top: 0.65rem;
    }

    :global(.system-trace__dot) {
      position: static;
      width: 0.5rem;
      height: 0.5rem;
    }

    :global(.system-trace small) {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.system-trace__line span) {
      transform: scaleX(1) !important;
    }
  }
</style>
