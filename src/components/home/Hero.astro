---
import ArrowLink from "@/components/ArrowLink.astro";
import { SystemTrace } from "@/components/islands/SystemTrace";
import { profile } from "@/data/profile";
---

<section class="hero page-shell" data-section-marker="Home" data-section-tone="quiet">
  <div class="hero__meta mono">
    <span data-i18n-zh={profile.availability} data-i18n-en="AVAILABLE FOR GOOD WORK">{profile.availability}</span>
    <span>{profile.timezone}</span>
    <span data-i18n-zh="中国，北京" data-i18n-en="BEIJING, CHINA">{profile.location}</span>
  </div>

  <div class="hero__grid">
    <div class="hero__copy">
      <p
        class="hero__role"
        data-i18n-zh={profile.role}
        data-i18n-en="AI Systems Engineer / Large Language Models"
      >
        {profile.role}
      </p>
      <h1 class="hero__headline">
        <span class="hero__headline-line" data-i18n-zh="从模型能力" data-i18n-en="FROM MODELS">从模型能力</span>
        <span class="hero__headline-line" data-i18n-zh="到系统能力" data-i18n-en="TO SYSTEMS">到系统能力</span>
      </h1>
      <p
        class="hero__thesis"
        data-i18n-zh={profile.thesis}
        data-i18n-en="Turning model capability into systems that ship, measure, and endure."
      >
        {profile.thesis}
      </p>
      <p
        class="hero__intro"
        data-i18n-zh={profile.intro}
        data-i18n-en="I care about one thing: turning model capability into reliable systems."
      >
        {profile.intro}
      </p>
      <div class="hero__actions">
        <ArrowLink href="/writing" label="阅读文章" labelEn="READ WRITING" variant="primary" />
        <ArrowLink href="/work" label="查看项目" labelEn="VIEW SYSTEMS" />
        <ArrowLink href="/resume" label="获取简历" labelEn="GET RESUME" />
      </div>
    </div>

    <aside class="hero__diagram" aria-label="System diagram">
      <div class="hero__diagram-meta mono">
        <span>Astro · MDX · Motion</span>
        <span>X 000512</span>
        <span>Y 000128</span>
      </div>
      <div class="diagram-node diagram-node--active">Agent</div>
      <div class="diagram-node diagram-node--a" data-i18n-zh="检索" data-i18n-en="Retrieval">检索</div>
      <div class="diagram-node diagram-node--b" data-i18n-zh="工具" data-i18n-en="Tools">工具</div>
      <div class="diagram-node diagram-node--c" data-i18n-zh="工作流" data-i18n-en="Workflow">工作流</div>
      <div class="diagram-cross diagram-cross--one"></div>
      <div class="diagram-cross diagram-cross--two"></div>
    </aside>
  </div>

  <SystemTrace client:visible />
</section>

<style>
  .hero {
    min-height: min(54rem, calc(92vh - 4.5rem));
    padding-top: clamp(2.5rem, 6vw, 5.5rem);
    padding-bottom: clamp(1.75rem, 4vw, 3rem);
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.25rem;
    margin-bottom: clamp(2rem, 4.2vw, 3.75rem);
    color: var(--color-muted);
    font-size: 0.68rem;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(20rem, 0.85fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: stretch;
  }

  .hero__role {
    margin: 0 0 1.4rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .hero__headline {
    max-width: 13ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(4.2rem, 8vw, 9.25rem);
    font-weight: 860;
    letter-spacing: 0;
    line-height: 0.84;
  }

  .hero__headline-line {
    display: block;
  }

  :global(html[data-language="zh"]) .hero__headline {
    max-width: 12ch;
    font-size: clamp(3.9rem, 6.35vw, 7rem);
    font-weight: 820;
    line-height: 0.98;
  }

  :global(html[data-language="zh"]) .hero__headline-line + .hero__headline-line {
    margin-top: 0.1em;
  }

  .hero__thesis {
    max-width: 44rem;
    margin: clamp(1.4rem, 3vw, 2.4rem) 0 0;
    font-size: clamp(1.25rem, 2vw, 2rem);
    line-height: 1.35;
  }

  .hero__intro {
    max-width: 38rem;
    margin: 1.25rem 0 0;
    color: #3c3a35;
    font-size: clamp(1rem, 1.35vw, 1.18rem);
    line-height: 1.9;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 2rem;
  }

  .hero__diagram {
    position: relative;
    min-height: 29rem;
    border-left: 1px solid var(--color-line);
    background:
      linear-gradient(to right, transparent 49.8%, rgba(17, 17, 17, 0.08) 50%, transparent 50.2%),
      linear-gradient(to bottom, transparent 49.8%, rgba(17, 17, 17, 0.08) 50%, transparent 50.2%);
  }

  .hero__diagram::before,
  .hero__diagram::after {
    position: absolute;
    inset: 20% 12%;
    content: "";
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-right: 0;
    border-bottom: 0;
  }

  .hero__diagram::after {
    inset: 38% 6% 18% 26%;
    border-color: rgba(199, 244, 50, 0.55);
  }

  .hero__diagram-meta {
    position: absolute;
    top: 0;
    right: 0;
    display: grid;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.66rem;
    text-align: right;
  }

  .diagram-node {
    position: absolute;
    border: 1px solid var(--color-line);
    padding: 0.55rem 0.75rem;
    background: color-mix(in srgb, var(--color-paper) 86%, white);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
  }

  .diagram-node--active {
    top: 42%;
    right: 18%;
    border-color: var(--color-lime);
  }

  .diagram-node--a {
    top: 27%;
    left: 18%;
  }

  .diagram-node--b {
    right: 8%;
    bottom: 27%;
  }

  .diagram-node--c {
    bottom: 16%;
    left: 28%;
  }

  .diagram-cross {
    position: absolute;
    width: 2rem;
    height: 2rem;
  }

  .diagram-cross::before,
  .diagram-cross::after {
    position: absolute;
    background: var(--color-line-strong);
    content: "";
  }

  .diagram-cross::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
  }

  .diagram-cross::after {
    top: 0;
    left: 50%;
    width: 1px;
    height: 100%;
  }

  .diagram-cross--one {
    top: 10%;
    right: 24%;
  }

  .diagram-cross--two {
    bottom: 7%;
    left: 18%;
  }

  :global(.system-trace) {
    position: relative;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1.4rem;
    margin-top: clamp(2rem, 4vw, 3.75rem);
    padding-top: 1.65rem;
  }

  :global(.system-trace__line) {
    position: absolute;
    top: 0.25rem;
    right: 0;
    left: 0;
    height: 1px;
    background: var(--color-line);
  }

  :global(.system-trace__line span) {
    display: block;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, var(--color-lime), var(--color-line));
    transform-origin: left;
  }

  :global(.system-trace__node) {
    position: relative;
    display: grid;
    gap: 0.55rem;
    min-height: 5rem;
  }

  :global(.system-trace__dot) {
    position: absolute;
    top: -1.75rem;
    left: 0;
    width: 0.58rem;
    height: 0.58rem;
    border: 1px solid var(--color-lime);
    background: var(--color-paper);
  }

  :global(.system-trace strong) {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
  }

  :global(.system-trace small) {
    max-width: 10rem;
    color: var(--color-muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  @media (max-width: 960px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }

    .hero__diagram {
      min-height: 18rem;
      border-top: 1px solid var(--color-line);
      border-left: 0;
    }

    :global(.system-trace) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      row-gap: 2rem;
    }
  }

  @media (min-width: 721px) {
    .hero__headline-line {
      white-space: nowrap;
    }
  }

  @media (max-width: 620px) {
    .hero {
      min-height: auto;
      padding-top: 1.8rem;
      padding-bottom: 1.4rem;
    }

    .hero__meta {
      margin-bottom: 1.55rem;
    }

    .hero__role {
      margin-bottom: 0.9rem;
      font-size: 0.68rem;
    }

    .hero__headline {
      font-size: clamp(3.55rem, 16vw, 4.2rem);
      line-height: 0.85;
    }

    :global(html[data-language="zh"]) .hero__headline {
      max-width: 8ch;
      font-size: clamp(3.15rem, 13vw, 4rem);
      line-height: 1;
    }

    .hero__thesis {
      margin-top: 1.1rem;
      font-size: 1.25rem;
    }

    .hero__intro {
      margin-top: 0.9rem;
      line-height: 1.75;
    }

    .hero__actions {
      margin-top: 1.45rem;
    }

    .hero__diagram {
      display: none;
    }

    :global(.system-trace) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem 1rem;
      margin-top: 1.55rem;
      padding-top: 0;
    }

    :global(.system-trace__line) {
      display: none;
    }

    :global(.system-trace__node) {
      gap: 0.4rem;
      min-height: 0;
      border-top: 1px solid var(--color-line);
      padding-top: 0.65rem;
    }

    :global(.system-trace__dot) {
      position: static;
      width: 0.5rem;
      height: 0.5rem;
    }

    :global(.system-trace small) {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.system-trace__line span) {
      transform: scaleX(1) !important;
    }
  }
</style>
