---
import SectionLabel from "@/components/SectionLabel.astro";

const tracks = [
  {
    title: "RAG & Document AI",
    titleEn: "RAG & Document AI",
    summary: "复杂文档解析、结构保护、混合检索、重排与评测闭环。",
    summaryEn: "Complex document parsing, structure preservation, hybrid retrieval, reranking, and evaluation loops."
  },
  {
    title: "Agent Runtime",
    titleEn: "Agent Runtime",
    summary: "状态、工具调用、审批、事件日志和可观测性，而不是循环调用模型。",
    summaryEn: "State, tool calling, approval, event logs, and observability beyond simply looping model calls."
  },
  {
    title: "Evaluation & Reliability",
    titleEn: "Evaluation & Reliability",
    summary: "用任务集、trace、人工审核和指标体系判断 AI 系统是否可靠。",
    summaryEn: "Task sets, traces, human review, and metrics that decide whether an AI system is reliable."
  },
  {
    title: "Production Engineering",
    titleEn: "Production Engineering",
    summary: "权限、延迟、失败归因、成本和维护边界，决定模型能力能否上线。",
    summaryEn: "Permissions, latency, failure attribution, cost, and maintenance boundaries that decide launchability."
  }
];
---

<section class="writing-tracks page-shell" data-home-section="02" data-section-tone="surface">
  <SectionLabel label="Writing Tracks" labelEn="Writing Tracks" kicker="Technical map" kickerEn="Technical map" />
  <div class="writing-tracks__intro">
    <p
      data-i18n-zh="我更关心一个问题：模型能力如何进入真实系统。写作会沿着 RAG、Agent Runtime、评测和工程边界持续展开。"
      data-i18n-en="I focus on one question: how model capability enters real systems. Writing will keep unfolding across RAG, Agent Runtime, evaluation, and engineering boundaries."
    >
      我更关心一个问题：模型能力如何进入真实系统。写作会沿着 RAG、Agent Runtime、评测和工程边界持续展开。
    </p>
  </div>
  <div class="writing-tracks__grid">
    {
      tracks.map((track, index) => (
        <article>
          <span class="mono">{String(index + 1).padStart(2, "0")}</span>
          <h3 data-i18n-zh={track.title} data-i18n-en={track.titleEn}>{track.title}</h3>
          <p data-i18n-zh={track.summary} data-i18n-en={track.summaryEn}>{track.summary}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .writing-tracks {
    border-top: 1px solid var(--color-line);
    padding-block: clamp(3rem, 7vw, 6rem);
  }

  .writing-tracks__intro {
    display: grid;
    grid-template-columns: minmax(0, 0.68fr) minmax(0, 1fr);
    margin-top: 1.6rem;
  }

  .writing-tracks__intro p {
    grid-column: 2;
    max-width: 46rem;
    margin: 0;
    font-size: clamp(1.25rem, 2.1vw, 2rem);
    line-height: 1.5;
  }

  .writing-tracks__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  article {
    min-height: 16rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: clamp(1rem, 2vw, 1.5rem);
  }

  article span {
    display: block;
    color: var(--color-muted);
    font-size: 0.68rem;
  }

  h3 {
    max-width: 10rem;
    margin: 2.8rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1.7vw, 1.55rem);
    line-height: 1.12;
  }

  p {
    margin: 1rem 0 0;
    color: var(--color-muted);
    line-height: 1.7;
  }

  @media (max-width: 980px) {
    .writing-tracks__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .writing-tracks__intro {
      grid-template-columns: 1fr;
    }

    .writing-tracks__intro p {
      grid-column: auto;
    }
  }

  @media (max-width: 560px) {
    .writing-tracks__grid {
      grid-template-columns: 1fr;
    }

    article {
      min-height: auto;
    }

    h3 {
      margin-top: 1.4rem;
    }
  }
</style>
