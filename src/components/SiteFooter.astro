---
import { profile } from "@/data/profile";

const resumeHref = "/resume";
---

<footer class="site-footer">
  <div class="site-footer__inner page-shell">
    <span>© 2026 {profile.handle}</span>
    <div class="site-footer__links" aria-label="Footer links">
      <a href={`mailto:${profile.email}`} data-i18n-zh="邮箱" data-i18n-en="EMAIL">邮箱</a>
      <a href={profile.github}>GITHUB</a>
      <a href={resumeHref} data-i18n-zh="简历" data-i18n-en="RESUME">简历</a>
    </div>
  </div>
</footer>
