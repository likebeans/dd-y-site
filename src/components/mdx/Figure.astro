---
interface Props {
  src?: string;
  alt?: string;
  caption?: string;
  variant?: "default" | "wide" | "full";
}

const { src, alt = "", caption, variant = "default" } = Astro.props;
---

<figure class:list={["figure", `figure--${variant}`]}>
  {src ? <img src={src} alt={alt} loading="lazy" /> : <slot />}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin: 2rem 0;
  }

  .figure--wide {
    width: min(100%, 64rem);
  }

  .figure--full {
    width: 100%;
  }

  img {
    width: 100%;
    border: 1px solid var(--color-line);
  }

  figcaption {
    margin-top: 0.6rem;
    color: var(--color-muted);
    font-size: 0.86rem;
    line-height: 1.6;
  }
</style>
