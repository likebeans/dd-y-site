---
import Icon from "@/components/Icon.astro";

interface Props {
  href: string;
  label: string;
  labelEn?: string;
  variant?: "primary" | "quiet";
}

const { href, label, labelEn = label, variant = "quiet" } = Astro.props;
---

<a class:list={["arrow-link", `arrow-link--${variant}`]} href={href}>
  <span data-i18n-zh={label} data-i18n-en={labelEn}>{label}</span>
  <Icon name="arrowUpRight" class="arrow-link__icon" />
</a>

<style>
  .arrow-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-height: 2.9rem;
    border: 1px solid var(--color-ink);
    padding-inline: 1.05rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition:
      background 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .arrow-link:hover {
    transform: translateY(-1px);
  }

  .arrow-link__icon {
    width: 0.82rem;
    height: 0.82rem;
    flex: 0 0 auto;
    transition: transform 180ms ease;
  }

  .arrow-link span {
    white-space: nowrap;
  }

  .arrow-link:hover .arrow-link__icon {
    transform: translate(1px, -1px);
  }

  .arrow-link--primary {
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .arrow-link--quiet {
    border-color: transparent;
  }

  .arrow-link--quiet:hover {
    background: rgba(17, 17, 17, 0.04);
  }
</style>
