---
import type { CollectionEntry } from "astro:content";

interface Props {
  works: CollectionEntry<"work">[];
}

const { works } = Astro.props;
---

<div class="work-index">
  {
    works.map((work) => (
      <a class="work-index__row" href={`/work/${work.id}`}>
        <span>{String(work.data.order).padStart(2, "0")}</span>
        <strong>{work.data.title}</strong>
        <small>{work.data.role}</small>
        <em>{work.data.year}</em>
      </a>
    ))
  }
</div>

<style>
  .work-index {
    border-top: 1px solid var(--color-line);
  }

  .work-index__row {
    display: grid;
    grid-template-columns: 3rem minmax(12rem, 1fr) minmax(10rem, 0.8fr) 4rem;
    gap: 1rem;
    align-items: center;
    border-bottom: 1px solid var(--color-line);
    padding-block: 1.35rem;
    transition:
      background 180ms ease,
      padding 180ms ease;
  }

  .work-index__row:hover {
    padding-left: 0.85rem;
    background: rgba(199, 244, 50, 0.08);
  }

  span,
  small,
  em {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-style: normal;
  }

  strong {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.8rem);
  }

  @media (max-width: 760px) {
    .work-index__row {
      grid-template-columns: 2.5rem minmax(0, 1fr) 3.5rem;
    }

    small {
      grid-column: 2 / -1;
    }
  }
</style>
