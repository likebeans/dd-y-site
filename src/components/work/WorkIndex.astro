---
import type { CollectionEntry } from "astro:content";

interface Props {
  works: CollectionEntry<"work">[];
}

const { works } = Astro.props;
---

<div class="work-index" data-work-index>
  {
    works.map((work) => {
      const signals = [...work.data.tags, ...work.data.stack.slice(0, 3)];

      return (
        <a class="work-index__row" href={`/work/${work.id}`} data-work-row>
          <span class="work-index__order">{String(work.data.order).padStart(2, "0")}</span>
          <div class="work-index__main">
            <strong>{work.data.title}</strong>
            <p data-work-summary>{work.data.summary}</p>
          </div>
          <div class="work-index__signals" data-work-signals>
            {signals.map((item) => (
              <span>{item}</span>
            ))}
          </div>
          <small>{work.data.role}</small>
          <em>{work.data.year}</em>
        </a>
      );
    })
  }
</div>

<style>
  .work-index {
    border-top: 1px solid var(--color-line);
  }

  .work-index__row {
    display: grid;
    grid-template-columns: 3rem minmax(16rem, 1.08fr) minmax(12rem, 0.74fr) minmax(9rem, 0.52fr) 4rem;
    gap: clamp(0.8rem, 2vw, 1.5rem);
    align-items: start;
    border-bottom: 1px solid var(--color-line);
    padding: 1.25rem 0;
    transition:
      background 180ms ease,
      padding 180ms ease;
  }

  .work-index__row:hover {
    padding-left: 0.85rem;
    background: rgba(199, 244, 50, 0.08);
  }

  .work-index__order,
  small,
  em {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-style: normal;
  }

  .work-index__main {
    display: grid;
    gap: 0.52rem;
  }

  strong {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.8rem);
    line-height: 1.05;
  }

  p {
    max-width: 42rem;
    margin: 0;
    color: #403d37;
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .work-index__signals {
    display: flex;
    flex-wrap: wrap;
    gap: 0.34rem;
  }

  .work-index__signals span {
    border: 1px solid var(--color-line);
    padding: 0.28rem 0.42rem;
    background: rgba(255, 255, 255, 0.18);
    color: var(--color-muted);
    font-size: 0.68rem;
    line-height: 1;
  }

  @media (max-width: 760px) {
    .work-index__row {
      grid-template-columns: 2.5rem minmax(0, 1fr) 3.5rem;
      gap: 0.7rem;
      padding: 1.15rem 0;
    }

    .work-index__main {
      grid-column: 2 / -1;
    }

    .work-index__signals,
    small {
      grid-column: 2 / -1;
    }

    em {
      grid-column: 3;
      grid-row: 1;
      justify-self: end;
    }
  }
</style>
