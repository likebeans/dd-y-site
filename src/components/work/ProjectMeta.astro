---
interface Props {
  year: number;
  role: string;
  status: string;
  stack: string[];
  tags: string[];
}

const { year, role, status, stack, tags } = Astro.props;
---

<aside class="project-meta" data-case-meta-rail>
  <dl>
    <div>
      <dt>Year</dt>
      <dd>{year}</dd>
    </div>
    <div>
      <dt>Role</dt>
      <dd>{role}</dd>
    </div>
    <div>
      <dt>Status</dt>
      <dd>{status}</dd>
    </div>
  </dl>
  <div class="project-meta__group">
    <p>Tags</p>
    <div class="project-meta__tags">
      {tags.map((item) => <span>{item}</span>)}
    </div>
  </div>
  <div class="project-meta__group">
    <p>Stack</p>
    <div class="project-meta__tags">
      {stack.map((item) => <span>{item}</span>)}
    </div>
  </div>
</aside>

<style>
  .project-meta {
    display: grid;
    gap: 1.35rem;
    color: var(--color-muted);
  }

  dl {
    display: grid;
    border-top: 1px solid var(--color-line);
    margin: 0;
  }

  dl div {
    border-bottom: 1px solid var(--color-line);
    padding-block: 0.82rem;
  }

  dt {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  dd {
    margin: 0.25rem 0 0;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .project-meta__group {
    display: grid;
    gap: 0.55rem;
  }

  p {
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .project-meta__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  span {
    border: 1px solid var(--color-line);
    padding: 0.28rem 0.45rem;
    font-size: 0.72rem;
  }
</style>
