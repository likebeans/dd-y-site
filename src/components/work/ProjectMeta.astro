---
import { toZhPhrase, toZhTerm } from "@/data/terms";

interface Props {
  year: number;
  role: string;
  status: string;
  statusLabelZh?: string;
  stack: string[];
  tags: string[];
}

const { year, role, status, statusLabelZh = status, stack, tags } = Astro.props;
---

<aside class="project-meta" data-case-meta-rail>
  <dl>
    <div>
      <dt data-i18n-zh="年份" data-i18n-en="Year">年份</dt>
      <dd>{year}</dd>
    </div>
    <div>
      <dt data-i18n-zh="角色" data-i18n-en="Role">角色</dt>
      <dd data-i18n-zh={toZhPhrase(role)} data-i18n-en={role}>{toZhPhrase(role)}</dd>
    </div>
    <div>
      <dt data-i18n-zh="状态" data-i18n-en="Status">状态</dt>
      <dd data-i18n-zh={statusLabelZh} data-i18n-en={status}>{statusLabelZh}</dd>
    </div>
  </dl>
  <div class="project-meta__group">
    <p data-i18n-zh="标签" data-i18n-en="Tags">标签</p>
    <div class="project-meta__tags">
      {tags.map((item) => <span data-i18n-zh={toZhTerm(item)} data-i18n-en={item}>{toZhTerm(item)}</span>)}
    </div>
  </div>
  <div class="project-meta__group">
    <p data-i18n-zh="技术栈" data-i18n-en="Stack">技术栈</p>
    <div class="project-meta__tags">
      {stack.map((item) => <span data-i18n-zh={toZhTerm(item)} data-i18n-en={item}>{toZhTerm(item)}</span>)}
    </div>
  </div>
</aside>

<style>
  .project-meta {
    display: grid;
    gap: 1.35rem;
    color: var(--color-muted);
  }

  dl {
    display: grid;
    border-top: 1px solid var(--color-line);
    margin: 0;
  }

  dl div {
    border-bottom: 1px solid var(--color-line);
    padding-block: 0.82rem;
  }

  dt {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  dd {
    margin: 0.25rem 0 0;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .project-meta__group {
    display: grid;
    gap: 0.55rem;
  }

  p {
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .project-meta__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  span {
    border: 1px solid var(--color-line);
    padding: 0.28rem 0.45rem;
    font-size: 0.72rem;
  }
</style>
