---
interface Metric {
  label: string;
  value: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
const metricLabelZh: Record<string, string> = {
  "Intent coverage": "意图覆盖",
  "Tool success": "工具成功率"
};
---

{
  metrics.length > 0 ? (
  <dl class="metric-strip">
    {metrics.map((metric) => (
      <div>
        <dt data-i18n-zh={metricLabelZh[metric.label] ?? metric.label} data-i18n-en={metric.label}>
          {metricLabelZh[metric.label] ?? metric.label}
        </dt>
        <dd>{metric.value}</dd>
      </div>
    ))}
  </dl>
  ) : (
    <div
      class="metric-strip metric-strip--empty"
      data-i18n-zh="可以稍后补充证据指标。"
      data-i18n-en="Evidence metrics can be added later."
    >
      可以稍后补充证据指标。
    </div>
  )
}

<style>
  .metric-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 0;
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
    margin: 2rem 0 0;
  }

  .metric-strip--empty {
    display: block;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: 1rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .metric-strip div {
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: 1rem;
  }

  dt {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  dd {
    margin: 0.5rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 780;
  }
</style>
