---
import { navItems } from "@/data/navigation";
import { profile } from "@/data/profile";

const normalizePath = (path: string) => path.replace(/\/$/, "") || "/";
const currentPath = normalizePath(Astro.url.pathname);

const isCurrentNavItem = (href: string) => {
  if (href.startsWith("http") || href.includes("#")) return false;

  const itemPath = normalizePath(new URL(href, Astro.url).pathname);
  return currentPath === itemPath || (itemPath !== "/" && currentPath.startsWith(`${itemPath}/`));
};
---

<header class="site-header">
  <div class="site-header__inner page-shell">
    <a class="site-header__brand" href="/" aria-label="dd-y / 余非凡 home">
      {profile.handle} / {profile.name}
    </a>
    <nav class="site-header__nav" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <a href={item.href} aria-current={isCurrentNavItem(item.href) ? "page" : undefined}>
            <span data-i18n-zh={item.label} data-i18n-en={item.labelEn}>{item.label}</span>
          </a>
        ))
      }
    </nav>
    <div class="site-header__language" role="group" aria-label="语言 / Language" data-language-switch>
      <button type="button" data-language-option="zh" aria-label="中文" aria-pressed="true">
        <span aria-hidden="true">中</span>
      </button>
      <button type="button" data-language-option="en" aria-label="English" aria-pressed="false">
        <span aria-hidden="true">EN</span>
      </button>
    </div>
  </div>
</header>
