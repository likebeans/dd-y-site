---
import { navItems } from "@/data/navigation";
import { profile } from "@/data/profile";
---

<header class="site-header">
  <div class="site-header__inner page-shell">
    <a class="site-header__brand" href="/" aria-label="dd-y / 余非凡 home">
      {profile.handle} / {profile.name}
    </a>
    <nav class="site-header__nav" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <a href={item.href}>
            <span data-i18n-zh={item.label} data-i18n-en={item.labelEn}>{item.label}</span>
          </a>
        ))
      }
    </nav>
    <div class="site-header__language" aria-label="Language">
      <button type="button" data-language-option="zh" aria-pressed="true">ZH</button>
      <button type="button" data-language-option="en" aria-pressed="false">EN</button>
    </div>
  </div>
</header>
