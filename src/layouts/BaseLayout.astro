---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import "@/styles/tokens.css";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title = "dd-y / 余非凡",
  description = "大模型算法工程师，关注 RAG、Agent、工具调用、评测与可上线的 AI 应用系统。",
  image = "/og-home.png",
  canonical = new URL(Astro.url.pathname, Astro.site ?? "https://yufeifan.cn").toString()
} = Astro.props;

const imageUrl = new URL(image, Astro.site ?? "https://yufeifan.cn").toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5f1e8" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="dd-y / 余非凡" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{title}</title>
  </head>
  <body>
    <div class="surface-field" data-surface-field aria-hidden="true">
      <div class="surface-field__sheet"></div>
      <div class="surface-field__contours" data-surface-contours></div>
      <div class="surface-field__cursor" data-cursor-instrument></div>
    </div>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storageKey = "dd-y-language";
        let currentLanguage = "zh";

        const readStoredLanguage = () => {
          try {
            return window.localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        };

        const writeStoredLanguage = (language) => {
          try {
            window.localStorage.setItem(storageKey, language);
          } catch {
            // Storage can be unavailable in privacy-focused contexts.
          }
        };

        const translateElement = (element, language) => {
          const translateNode = (node) => {
            const text = node.getAttribute(`data-i18n-${language}`);
            if (text !== null) {
              node.textContent = text;
            }
          };

          if (element.matches("[data-i18n-zh][data-i18n-en]")) {
            translateNode(element);
          }

          element.querySelectorAll("[data-i18n-zh][data-i18n-en]").forEach(translateNode);
        };

        const applyLanguage = (language) => {
          const nextLanguage = language === "en" ? "en" : "zh";
          currentLanguage = nextLanguage;
          root.lang = nextLanguage === "en" ? "en" : "zh-CN";
          root.dataset.language = nextLanguage;

          translateElement(document.body, nextLanguage);

          document.querySelectorAll("[data-language-option]").forEach((node) => {
            node.setAttribute("aria-pressed", String(node.getAttribute("data-language-option") === nextLanguage));
          });

          writeStoredLanguage(nextLanguage);
        };

        document.addEventListener("click", (event) => {
          const target = event.target instanceof Element ? event.target.closest("[data-language-option]") : null;
          if (!target) return;
          applyLanguage(target.getAttribute("data-language-option"));
        });

        const translationObserver = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            mutation.addedNodes.forEach((node) => {
              if (node instanceof Element) {
                translateElement(node, currentLanguage);
              }
            });
          });
        });

        translationObserver.observe(document.body, { childList: true, subtree: true });

        let pointerFrame = 0;
        const setPointer = (event) => {
          if (pointerFrame) window.cancelAnimationFrame(pointerFrame);
          pointerFrame = window.requestAnimationFrame(() => {
            root.style.setProperty("--cursor-x", `${Math.round(event.clientX)}px`);
            root.style.setProperty("--cursor-y", `${Math.round(event.clientY)}px`);
          });
        };

        let scrollFrame = 0;
        const setScrollDepth = () => {
          if (scrollFrame) window.cancelAnimationFrame(scrollFrame);
          scrollFrame = window.requestAnimationFrame(() => {
            const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
            const progress = Math.min(1, Math.max(0, window.scrollY / maxScroll));
            root.style.setProperty("--scroll-progress", progress.toFixed(4));
            root.style.setProperty("--surface-y", `${Math.round(progress * 220)}px`);
            root.style.setProperty("--surface-tilt", `${(7 + progress * 7).toFixed(2)}deg`);
          });
        };

        window.addEventListener("pointermove", setPointer, { passive: true });
        window.addEventListener("scroll", setScrollDepth, { passive: true });
        window.addEventListener("resize", setScrollDepth);
        setScrollDepth();
        applyLanguage(readStoredLanguage());
      })();
    </script>
  </body>
</html>
