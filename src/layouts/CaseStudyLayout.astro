---
import type { CollectionEntry } from "astro:content";
import ArrowLink from "@/components/ArrowLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArchitectureFigure from "@/components/work/ArchitectureFigure.astro";
import MetricStrip from "@/components/work/MetricStrip.astro";
import ProjectMeta from "@/components/work/ProjectMeta.astro";

interface Props {
  entry: CollectionEntry<"work">;
}

const { entry } = Astro.props;
const statusLabelZh = entry.data.status === "Case Study" ? "案例研究" : entry.data.status;
const architectureTitleZh = `${entry.data.title} 架构`;
const architectureTitleEn = `${entry.data.title} Architecture`;
const caseUrl = `https://yufeifan.cn/work/${entry.id}`;
const caseStructuredData = {
  "@type": "CreativeWork",
  headline: entry.data.title,
  name: entry.data.title,
  description: entry.data.summary,
  url: caseUrl,
  dateCreated: `${entry.data.year}-01-01`,
  inLanguage: "zh-CN",
  creator: {
    "@id": "https://yufeifan.cn/#person"
  },
  keywords: [...entry.data.tags, ...entry.data.stack].join(", ")
};
---

<BaseLayout
  title={`${entry.data.title} - dd-y / 余非凡`}
  description={entry.data.summary}
  canonical={caseUrl}
  structuredData={caseStructuredData}
>
  <article class="case-study page-shell">
    <header class="case-study__hero" id="overview">
      <div>
        <p class="case-study__eyebrow" data-i18n-zh={statusLabelZh} data-i18n-en={entry.data.status}>
          {statusLabelZh}
        </p>
        <h1>{entry.data.title}</h1>
        <p data-i18n-zh={entry.data.summary} data-i18n-en={entry.data.summaryEn}>{entry.data.summary}</p>
      </div>
      <ProjectMeta
        year={entry.data.year}
        role={entry.data.role}
        status={entry.data.status}
        statusLabelZh={statusLabelZh}
        stack={entry.data.stack}
        tags={entry.data.tags}
      />
    </header>

    <section class="case-study__snapshot" id="snapshot" data-case-snapshot>
      <div class="case-study__snapshot-head">
        <p data-i18n-zh="系统快照" data-i18n-en="System Snapshot">系统快照</p>
        <span
          data-i18n-zh="架构、信号与证据会先于正文呈现。"
          data-i18n-en="Architecture, signals, and evidence live here before the narrative."
        >
          架构、信号与证据会先于正文呈现。
        </span>
      </div>
      <MetricStrip metrics={entry.data.metrics} />
      <ArchitectureFigure title={architectureTitleZh} titleEn={architectureTitleEn} />
    </section>

    <div class="case-study__body">
      <nav aria-label="Case study sections" data-case-nav>
        <a href="#overview" data-i18n-zh="概览" data-i18n-en="Overview">概览</a>
        <a href="#snapshot" data-i18n-zh="快照" data-i18n-en="Snapshot">快照</a>
        <a href="#case-notes" data-i18n-zh="案例正文" data-i18n-en="Case Notes">案例正文</a>
        <a href="#next" data-i18n-zh="下一步" data-i18n-en="Next">下一步</a>
      </nav>
      <div class="case-study__content" id="case-notes" data-case-content data-language-only="zh">
        <slot />
      </div>
      <div class="case-study__content" data-case-content data-language-only="en">
        {entry.data.sectionsEn.map((section) => (
          <section>
            <h2>{section.heading}</h2>
            {section.body.map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))}
      </div>
    </div>

    <footer class="case-study__next" id="next" data-case-next>
      <div>
        <p data-i18n-zh="继续浏览" data-i18n-en="Continue">继续浏览</p>
        <span
          data-i18n-zh="在项目证据、技术文章和简历之间继续浏览。"
          data-i18n-en="Move between project evidence, writing, and resume without leaving the portfolio system."
        >
          在项目证据、技术文章和简历之间继续浏览。
        </span>
      </div>
      <div class="case-study__next-actions">
        <ArrowLink href="/work" label="所有项目" labelEn="ALL WORK" />
        <ArrowLink href="/writing" label="阅读文章" labelEn="READ WRITING" />
        <ArrowLink href="/resume" label="查看简历" labelEn="RESUME" />
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .case-study {
    padding-top: clamp(3rem, 7vw, 6rem);
  }

  .case-study__hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(14rem, 0.34fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
  }

  .case-study__eyebrow {
    margin: 0 0 1.2rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 12ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 8vw, 8.5rem);
    font-weight: 840;
    letter-spacing: 0;
    line-height: 0.88;
  }

  .case-study__hero p:not(.case-study__eyebrow) {
    max-width: 42rem;
    margin: 1.5rem 0 0;
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    line-height: 1.7;
  }

  .case-study__snapshot {
    display: grid;
    grid-template-columns: minmax(0, 0.26fr) minmax(0, 0.74fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-block: clamp(1.4rem, 3vw, 2.2rem);
    scroll-margin-top: 7rem;
  }

  .case-study__snapshot-head {
    display: grid;
    align-content: start;
    gap: 0.75rem;
  }

  .case-study__snapshot-head p,
  .case-study__next p {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .case-study__snapshot-head span,
  .case-study__next span {
    max-width: 20rem;
    color: var(--color-muted);
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .case-study__snapshot :global(.metric-strip),
  .case-study__snapshot :global(.architecture-figure) {
    grid-column: 2;
  }

  .case-study__snapshot :global(.metric-strip) {
    margin-top: 0;
  }

  .case-study__body {
    display: grid;
    grid-template-columns: minmax(9rem, 0.24fr) minmax(0, 0.76fr);
    gap: clamp(2rem, 5vw, 5rem);
    margin-top: clamp(3rem, 6vw, 5rem);
  }

  nav {
    position: sticky;
    top: 6rem;
    display: grid;
    gap: 0.7rem;
    align-self: start;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  nav a:hover {
    color: var(--color-ink);
  }

  .case-study__content {
    max-width: 52rem;
  }

  .case-study__content :global(h2) {
    scroll-margin-top: 7rem;
    margin: 3rem 0 1rem;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1.08;
  }

  .case-study__content :global(h2:first-child) {
    margin-top: 0;
  }

  .case-study__content :global(p),
  .case-study__content :global(li) {
    color: #35332f;
    font-size: 1.02rem;
    line-height: 1.9;
  }

  .case-study__content :global(ul) {
    padding-left: 1.2rem;
  }

  .case-study__next {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    border-top: 1px solid var(--color-line);
    margin-top: clamp(3rem, 6vw, 5rem);
    padding-block: 1.4rem;
    scroll-margin-top: 7rem;
  }

  .case-study__next div:first-child {
    display: grid;
    gap: 0.6rem;
  }

  .case-study__next-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.2rem;
    align-items: start;
    justify-content: flex-end;
  }

  @media (max-width: 860px) {
    .case-study__hero,
    .case-study__snapshot,
    .case-study__body {
      grid-template-columns: 1fr;
    }

    .case-study__snapshot :global(.metric-strip),
    .case-study__snapshot :global(.architecture-figure) {
      grid-column: 1;
    }

    nav {
      position: static;
      display: flex;
      flex-wrap: wrap;
      border-top: 1px solid var(--color-line);
      border-bottom: 1px solid var(--color-line);
      padding-block: 1rem;
    }

    .case-study__next {
      flex-direction: column;
    }

    .case-study__next-actions {
      justify-content: flex-start;
    }
  }
</style>
